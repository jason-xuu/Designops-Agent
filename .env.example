# Default provider is Ollama (runs 100% locally, no API key, no cost).
# Set LLM_PROVIDER=none to run the agent in pure-deterministic mode (LLM calls skipped).
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_S=180

# Ollama OpenAI-compatible endpoint. Override only if you run Ollama on a non-default host/port.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Runtime storage
SQLITE_PATH=designops_runs.db
